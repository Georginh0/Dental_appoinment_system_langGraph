# ============================================================
#  DentAI Pro — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — it is in .gitignore.
#  NEVER put real keys in .env.example — only placeholders.
# ============================================================

# ── Groq (free LLM) ─────────────────────────────────────────
# Get key: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY

# ── Supabase / PostgreSQL ────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string
# Use "Session pooler" (port 5432) — username format: postgres.PROJECTREF
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-1-eu-west-2.pooler.supabase.com:5432/postgres

# ── Telegram Bot ─────────────────────────────────────────────
# Get from: Telegram → @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Any random 32-char string — used to verify webhook calls
TELEGRAM_WEBHOOK_SECRET=replace_with_random_32_char_string

# ── Twilio (WhatsApp) ────────────────────────────────────────
# Get from: twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_32_char_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── FastAPI JWT (api/main.py) ────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Optional ─────────────────────────────────────────────────
LOG_LEVEL=INFO
